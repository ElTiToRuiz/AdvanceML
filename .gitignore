# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
build/
dist/
wheels/
*.egg-info/

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
ENV/

# ─── IDEs / editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS junk ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs / databases ────────────────────────────────────────────────────────
*.log
*.sqlite3

# ─── Project data + outputs (regenerable) ───────────────────────────────────
# Raw + processed CSVs (regenerated by data.download / data.clean).
# Leading slash anchors the rule to the project root so that subpackages
# named `data/` (e.g. src/activity1/data/, src/activity2/data/) stay tracked.
/data/

# All generated charts, metrics tables, and the .pptx (regenerated by pipelines)
/reports/

# Fine-tuned Chronos-2 checkpoint (~500 MB, regenerated by finetune_chronos)
chronos-2-finetuned/

# Helper build scripts (deliverables are the .pptx / .docx they produce)
scripts/

# ─── Course handouts / personal scratch ─────────────────────────────────────
*.docx
*.pdf
class/

# ─── Claude Code session metadata ───────────────────────────────────────────
.claude/
